{
	"compilerOptions": {
		"target": "ES2022",
		"module": "NodeNext",
		"moduleResolution": "NodeNext",
		"lib": ["ES2022", "DOM"],
		"strict": true,
		"noEmit": false,
		"declaration": true,
		"outDir": "./dist",
		"rootDir": "./src",
		"esModuleInterop": true,
		"skipLibCheck": true,
		"jsx": "react-jsx",
		"types": ["node", "ws"]
	},
	"include": ["src/**/*"],
	"exclude": ["node_modules", "dist"]
}
